FROM hsliup/tradingagents-backend:v1.0.0-preview

RUN python - <<'PY'
from pathlib import Path

path = Path("/app/app/services/config_service.py")
text = path.read_text()
start = text.index("    def _test_deepseek_api(")
end = text.index("    def _test_dashscope_api(", start)
block = text[start:end]

old_payload = '''                "max_tokens": 50,
                "temperature": 0.1
            }'''
new_payload = '''                "max_tokens": 50,
                "temperature": 0.1,
                "thinking": {"type": "disabled"}
            }'''
if old_payload not in block:
    raise RuntimeError("DeepSeek test payload pattern not found")
block = block.replace(old_payload, new_payload, 1)

old_content = '                    content = result["choices"][0]["message"]["content"]'
new_content = '''                    message = result["choices"][0].get("message", {})
                    content = message.get("content") or message.get("reasoning_content")'''
if old_content not in block:
    raise RuntimeError("DeepSeek content extraction pattern not found")
block = block.replace(old_content, new_content, 1)

path.write_text(text[:start] + block + text[end:])
PY

RUN python -m py_compile /app/app/services/config_service.py

RUN python - <<'PY'
from pathlib import Path

path = Path("/app/app/services/simple_analysis_service.py")
text = path.read_text()

if "def _sanitize_analysis_error(error: Exception) -> str:" not in text:
    marker = "import logging\n"
    if marker not in text:
        raise RuntimeError("logging import marker not found")
    text = text.replace(marker, marker + "import re\n", 1)

    marker = "# 配置服务实例\nconfig_service = ConfigService()\n"
    helper = '''# 配置服务实例
config_service = ConfigService()


def _sanitize_analysis_error(error: Exception) -> str:
    """Return diagnostic error text without leaking API keys or bearer tokens."""
    message = f"{type(error).__name__}: {str(error)}"
    patterns = [
        (r"sk-[A-Za-z0-9_\\-]{8,}", "sk-***"),
        (r"(Bearer\\s+)[A-Za-z0-9._\\-]+", r"\\1***"),
        (r"(?i)(api[_-]?key['\\"\\s:=]+)[^,'\\"\\s]+", r"\\1***"),
        (r"(?i)(authorization['\\"\\s:=]+)[^,'\\"\\s]+", r"\\1***"),
    ]
    for pattern, replacement in patterns:
        message = re.sub(pattern, replacement, message)
    return message[:2000]
'''
    if marker not in text:
        raise RuntimeError("config service marker not found")
    text = text.replace(marker, helper, 1)

text = text.replace(
    'logger.error(f"❌ 后台分析任务失败: {task_id} - {e}")',
    'logger.error(f"❌ 后台分析任务失败: {task_id} - {e}", exc_info=True)',
)
text = text.replace(
    'logger.error(f"❌ [线程池] 分析执行失败: {task_id} - {e}")',
    'logger.error(f"❌ [线程池] 分析执行失败: {task_id} - {e}", exc_info=True)',
)

needle = '''            user_friendly_error = (
                f"{formatted_error['title']}\\n\\n"
                f"{formatted_error['message']}\\n\\n"
                f"💡 {formatted_error['suggestion']}"
            )
'''
replacement = needle + '''            diagnostic_error = _sanitize_analysis_error(e)
            user_friendly_error = (
                f"{user_friendly_error}\\n\\n"
                f"🔎 技术细节（已脱敏）:\\n{diagnostic_error}"
            )
'''
count = text.count(needle)
if count < 2:
    raise RuntimeError(f"expected at least 2 user_friendly_error blocks, found {count}")
text = text.replace(needle, replacement, 2)

path.write_text(text)
PY

RUN python -m py_compile /app/app/services/simple_analysis_service.py

RUN python - <<'PY'
from pathlib import Path

candidate_paths = [
    Path("/app/tradingagents/llm_clients/openai_client.py"),
    Path("/app/tradingagents/llm_adapters/deepseek_adapter.py"),
]
patched = False

llm_client_path = candidate_paths[0]
if llm_client_path.exists():
    text = llm_client_path.read_text()
    needle = '''        for key in _PASSTHROUGH_KWARGS:
            if key in self.kwargs:
                llm_kwargs[key] = self.kwargs[key]

        return NormalizedChatOpenAI(**llm_kwargs)
'''
    replacement = '''        for key in _PASSTHROUGH_KWARGS:
            if key in self.kwargs:
                llm_kwargs[key] = self.kwargs[key]

        if self.provider == "deepseek":
            llm_kwargs.setdefault("extra_body", {"thinking": {"type": "disabled"}})

        return NormalizedChatOpenAI(**llm_kwargs)
'''
    if replacement not in text:
        if needle not in text:
            raise RuntimeError("OpenAI client insertion point not found")
        text = text.replace(needle, replacement, 1)
        llm_client_path.write_text(text)
    patched = True

deepseek_adapter_path = candidate_paths[1]
if deepseek_adapter_path.exists():
    text = deepseek_adapter_path.read_text()
    needle = '''            temperature=temperature,
            max_tokens=max_tokens,
            **kwargs
        )
'''
    replacement = '''            temperature=temperature,
            max_tokens=max_tokens,
            extra_body={"thinking": {"type": "disabled"}},
            **kwargs
        )
'''
    if replacement not in text:
        if needle not in text:
            raise RuntimeError("DeepSeek adapter insertion point not found")
        text = text.replace(needle, replacement, 1)
        deepseek_adapter_path.write_text(text)
    patched = True

if not patched:
    raise RuntimeError("No DeepSeek LLM client path found")
PY

RUN python -m py_compile \
    $(test -f /app/tradingagents/llm_clients/openai_client.py && echo /app/tradingagents/llm_clients/openai_client.py) \
    $(test -f /app/tradingagents/llm_adapters/deepseek_adapter.py && echo /app/tradingagents/llm_adapters/deepseek_adapter.py)
